# Vertex AI (Google Cloud)
VERTEX_PROJECT_ID=your-project-id-here
VERTEX_LOCATION=us-central1

# GitHub API Token (for Advisory collection)
GITHUB_TOKEN=your-github-token-here

# Gemini API Keys (comma-separated for rotation)
GEMINI_API_KEYS=key1,key2,key3

# Data paths (optional override)
GITHUB_POC_REPO_PATH=./data/PoC-in-GitHub
VULHUB_PATH=./data/vulhub
EXPLOITDB_PATH=./data/exploitdb_full
EXPLOITDB_CSV=./data/exploitdb/files_exploits.csv
METASPLOIT_PATH=./data/metasploit

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cve_database
DB_USER=postgres
DB_PASSWORD=your-password-here
